+++ b/src/workflows/types.ts
@@ -0,0 +1,104 @@
+import type { PiboJsonObject } from "../core/events.js";
+
+export type WorkflowUsageMode = "session-only" | "internal";
+export type WorkflowRunStatus = "pending" | "running" | "waiting" | "completed" | "failed" | "discarded";
+export type WorkflowNodeKind = "function" | "runtime" | "user" | "terminal";
+export type WorkflowSessionLinkRole = "main" | "sub";
+
+export type WorkflowNodeDefinition = {
+	id: string;
+	kind: WorkflowNodeKind;
+	terminal?: boolean;
+	expectedActions?: string[];
+};
+
+export type WorkflowEdgeDefinition = {
+	id: string;
+	from: string;
+	to: string;
+	action?: string;
+	priority?: number;
+};
+
+export type WorkflowDefinition = {
+	id: string;
+	version: string;
+	usage: WorkflowUsageMode;
+	initialNodeId: string;
+	maxRetries?: number;
+	nodes: WorkflowNodeDefinition[];
+	edges: WorkflowEdgeDefinition[];
+};
+
+export type WorkflowRun = {
+	id: string;
+	workflowId: string;
+	workflowVersion: string;
+	usage: WorkflowUsageMode;
+	ownerScope: string;
+	status: WorkflowRunStatus;
+	currentNodeId: string;
+	projectId?: string;
+	retryCount: number;
+	maxRetries: number;
+	state: PiboJsonObject;
+	initiator: string;
+	waitingActions: string[];
+	latestReason?: string;
+	createdAt: string;
+	updatedAt: string;
+	completedAt?: string;
+};
+
+export type WorkflowTraceEventType =
+	| "workflow.created"
+	| "workflow.started"
+	| "workflow.node_started"
+	| "workflow.node_completed"
+	| "workflow.transition_taken"
+	| "workflow.state_changed"
+	| "workflow.waiting"
+	| "workflow.user_feedback"
+	| "workflow.retry"
+	| "workflow.completed"
+	| "workflow.failed"
+	| "workflow.discarded";
+
+export type WorkflowTraceEvent = {
+	id: string;
+	workflowRunId: string;
+	sequence: number;
+	type: WorkflowTraceEventType;
+	nodeId?: string;
+	fromNodeId?: string;
+	toNodeId?: string;
+	actorId?: string;
+	reason?: string;
+	payload: PiboJsonObject;
+	createdAt: string;
+};
+
+export type WorkflowSessionLink = {
+	workflowRunId: string;
+	piboSessionId: string;
+	role: WorkflowSessionLinkRole;
+	createdAt: string;
+};
+
+export type StartWorkflowInput = {
+	workflowId: string;
+	workflowVersion?: string;
+	usage: WorkflowUsageMode;
+	ownerScope: string;
+	projectId?: string;
+	mainPiboSessionId?: string;
+	initiator: string;
+	state?: PiboJsonObject;
+};
+
+export type ResumeWorkflowInput = {
+	workflowRunId: string;
+	action: string;
+	actorId: string;
+	reason?: string;
+};
