@@ -0,0 +1,98 @@
+import type { PiboJsonObject } from "../core/events.js";
+import { WorkflowRegistry } from "./registry.js";
+import { WorkflowStore } from "./store.js";
+import type { ResumeWorkflowInput, StartWorkflowInput, WorkflowRun } from "./types.js";
+
+export class WorkflowRunner {
+	constructor(private readonly registry: WorkflowRegistry, private readonly store: WorkflowStore) {}
+
+	start(input: StartWorkflowInput): WorkflowRun {
+		const definition = this.registry.get(input.workflowId, input.workflowVersion);
+		if (!definition) throw new Error(`Workflow ${input.workflowId} is not registered`);
+		if (definition.usage !== input.usage) throw new Error(`Workflow ${definition.id} requires ${definition.usage} usage`);
+		let run = this.store.createRun({
+			workflowId: definition.id,
+			workflowVersion: definition.version,
+			usage: definition.usage,
+			ownerScope: input.ownerScope,
+			status: "running",
+			currentNodeId: definition.initialNodeId,
+			projectId: input.projectId,
+			retryCount: 0,
+			maxRetries: definition.maxRetries ?? 0,
+			state: input.state ?? {},
+			initiator: input.initiator,
+			waitingActions: [],
+		});
+		this.store.appendTrace({ workflowRunId: run.id, type: "workflow.created", nodeId: run.currentNodeId, actorId: input.initiator, payload: {} });
+		this.store.appendTrace({ workflowRunId: run.id, type: "workflow.started", nodeId: run.currentNodeId, actorId: input.initiator, payload: {} });
+		if (input.mainPiboSessionId) this.store.linkSession({ workflowRunId: run.id, piboSessionId: input.mainPiboSessionId, role: "main" });
+		run = this.advanceAutomatic(run);
+		return run;
+	}
+
+	resume(input: ResumeWorkflowInput): WorkflowRun {
+		const run = this.requireRun(input.workflowRunId);
+		const definition = this.registry.get(run.workflowId, run.workflowVersion);
+		if (!definition) throw new Error(`Workflow ${run.workflowId} is not registered`);
+		if (run.status !== "waiting") throw new Error("Workflow is not waiting for user feedback");
+		const edge = definition.edges.find((candidate) => candidate.from === run.currentNodeId && candidate.action === input.action);
+		if (!edge) throw new Error(`Action ${input.action} is not allowed from ${run.currentNodeId}`);
+		this.store.appendTrace({ workflowRunId: run.id, type: "workflow.user_feedback", nodeId: run.currentNodeId, actorId: input.actorId, reason: input.reason, payload: { action: input.action } as PiboJsonObject });
+		let nextRun = this.transition(run, edge.to, input.reason);
+		if (input.action === "request_changes") {
+			nextRun = { ...nextRun, retryCount: nextRun.retryCount + 1 };
+			this.store.appendTrace({ workflowRunId: nextRun.id, type: "workflow.retry", nodeId: nextRun.currentNodeId, actorId: input.actorId, reason: input.reason, payload: { retryCount: nextRun.retryCount } });
+			this.store.updateRun(nextRun);
+		}
+		return this.advanceAutomatic(nextRun);
+	}
+
+	private advanceAutomatic(run: WorkflowRun): WorkflowRun {
+		let current = run;
+		while (true) {
+			const definition = this.registry.get(current.workflowId, current.workflowVersion);
+			if (!definition) return current;
+			const node = definition.nodes.find((candidate) => candidate.id === current.currentNodeId);
+			if (!node) return current;
+			this.store.appendTrace({ workflowRunId: current.id, type: "workflow.node_started", nodeId: node.id, payload: {} });
+			if (current.state.manual === true && !node.terminal) {
+				current = this.store.updateRun({
+					...current,
+					status: "waiting",
+					waitingActions: definition.edges.filter((edge) => edge.from === node.id).map((edge) => edge.to),
+				});
+				this.store.appendTrace({ workflowRunId: current.id, type: "workflow.waiting", nodeId: node.id, payload: { manual: true, nextNodes: current.waitingActions } });
+				return current;
+			}
+			if (node.kind === "user") {
+				current = this.store.updateRun({ ...current, status: "waiting", waitingActions: node.expectedActions ?? [] });
+				this.store.appendTrace({ workflowRunId: current.id, type: "workflow.waiting", nodeId: node.id, payload: { actions: current.waitingActions } });
+				return current;
+			}
+			if (node.terminal) {
+				const status = node.id === "failed" ? "failed" : node.id === "discarded" ? "discarded" : "completed";
+				current = this.store.updateRun({ ...current, status, waitingActions: [], completedAt: new Date().toISOString() });
+				this.store.appendTrace({ workflowRunId: current.id, type: status === "failed" ? "workflow.failed" : status === "discarded" ? "workflow.discarded" : "workflow.completed", nodeId: node.id, payload: {} });
+				return current;
+			}
+			this.store.appendTrace({ workflowRunId: current.id, type: "workflow.node_completed", nodeId: node.id, payload: {} });
+			const edge = definition.edges.filter((candidate) => candidate.from === node.id && !candidate.action).sort((left, right) => (left.priority ?? 0) - (right.priority ?? 0))[0];
+			if (!edge) return this.store.updateRun({ ...current, status: "failed", latestReason: `No transition from ${node.id}`, completedAt: new Date().toISOString() });
+			current = this.transition(current, edge.to);
+		}
+	}
+
+	private transition(run: WorkflowRun, toNodeId: string, reason?: string): WorkflowRun {
+		this.store.appendTrace({ workflowRunId: run.id, type: "workflow.transition_taken", fromNodeId: run.currentNodeId, toNodeId, reason, payload: {} });
+		const next = this.store.updateRun({ ...run, status: "running", currentNodeId: toNodeId, waitingActions: [], latestReason: reason });
+		this.store.appendTrace({ workflowRunId: run.id, type: "workflow.state_changed", fromNodeId: run.currentNodeId, toNodeId, reason, payload: {} });
+		return next;
+	}
+
+	private requireRun(id: string): WorkflowRun {
+		const run = this.store.getRun(id);
+		if (!run) throw new Error("Workflow run not found");
+		return run;
+	}
+}
