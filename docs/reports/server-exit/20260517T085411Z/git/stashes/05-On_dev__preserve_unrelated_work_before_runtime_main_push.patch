index 0000000..da3d172
--- /dev/null
+++ b/src/workflows/registry.ts
@@ -0,0 +1,52 @@
+import type { WorkflowDefinition } from "./types.js";
+
+export class WorkflowRegistry {
+	private readonly definitions = new Map<string, WorkflowDefinition>();
+
+	register(definition: WorkflowDefinition): void {
+		validateWorkflowDefinition(definition);
+		const key = definitionKey(definition.id, definition.version);
+		if (this.definitions.has(key)) throw new Error(`Workflow ${definition.id}@${definition.version} is already registered`);
+		this.definitions.set(key, definition);
+	}
+
+	get(id: string, version?: string): WorkflowDefinition | undefined {
+		if (version) return this.definitions.get(definitionKey(id, version));
+		return [...this.definitions.values()].filter((definition) => definition.id === id).sort((left, right) => right.version.localeCompare(left.version))[0];
+	}
+
+	list(): WorkflowDefinition[] {
+		return [...this.definitions.values()].sort((left, right) => `${left.id}@${left.version}`.localeCompare(`${right.id}@${right.version}`));
+	}
+}
+
+export function validateWorkflowDefinition(definition: WorkflowDefinition): void {
+	if (!definition.id.trim()) throw new Error("Workflow id is required");
+	if (!definition.version.trim()) throw new Error("Workflow version is required");
+	if (definition.usage !== "session-only" && definition.usage !== "internal") throw new Error("Workflow usage is invalid");
+	if (!Number.isInteger(definition.maxRetries ?? 0) || (definition.maxRetries ?? 0) < 0) throw new Error("Workflow maxRetries must be bounded");
+	const nodeIds = new Set<string>();
+	for (const node of definition.nodes) {
+		if (!node.id.trim()) throw new Error("Workflow node id is required");
+		if (nodeIds.has(node.id)) throw new Error(`Duplicate workflow node ${node.id}`);
+		nodeIds.add(node.id);
+	}
+	if (!nodeIds.has(definition.initialNodeId)) throw new Error("Workflow initial node must exist");
+	const edgeIds = new Set<string>();
+	const edgeKeys = new Set<string>();
+	for (const edge of definition.edges) {
+		if (!edge.id.trim()) throw new Error("Workflow edge id is required");
+		if (edgeIds.has(edge.id)) throw new Error(`Duplicate workflow edge ${edge.id}`);
+		edgeIds.add(edge.id);
+		if (!nodeIds.has(edge.from) || !nodeIds.has(edge.to)) throw new Error(`Workflow edge ${edge.id} has an invalid endpoint`);
+		const priority = edge.priority ?? 0;
+		if (!Number.isInteger(priority)) throw new Error(`Workflow edge ${edge.id} priority must be an integer`);
+		const key = `${edge.from}:${edge.action ?? ""}:${priority}`;
+		if (edgeKeys.has(key)) throw new Error(`Workflow edge priorities from ${edge.from} must be deterministic`);
+		edgeKeys.add(key);
+	}
+}
+
+function definitionKey(id: string, version: string): string {
+	return `${id}@${version}`;
+}
