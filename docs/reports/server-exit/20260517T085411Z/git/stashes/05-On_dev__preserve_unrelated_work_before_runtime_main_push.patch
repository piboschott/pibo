diff --git a/src/workflows/store.ts b/src/workflows/store.ts
new file mode 100644
index 0000000..a196997
--- /dev/null
+++ b/src/workflows/store.ts
@@ -0,0 +1,147 @@
+import { randomUUID } from "node:crypto";
+import { mkdirSync } from "node:fs";
+import { dirname, resolve } from "node:path";
+import { DatabaseSync } from "node:sqlite";
+import { piboHomePath } from "../core/pibo-home.js";
+import type { PiboJsonObject } from "../core/events.js";
+import type { WorkflowRun, WorkflowSessionLink, WorkflowTraceEvent, WorkflowTraceEventType, WorkflowUsageMode } from "./types.js";
+
+type RunRow = { id: string; workflow_id: string; workflow_version: string; usage: WorkflowUsageMode; owner_scope: string; status: WorkflowRun["status"]; current_node_id: string; project_id: string | null; retry_count: number; max_retries: number; state_json: string; initiator: string; waiting_actions_json: string; latest_reason: string | null; created_at: string; updated_at: string; completed_at: string | null };
+type TraceRow = { id: string; workflow_run_id: string; sequence: number; type: WorkflowTraceEventType; node_id: string | null; from_node_id: string | null; to_node_id: string | null; actor_id: string | null; reason: string | null; payload_json: string; created_at: string };
+type LinkRow = { workflow_run_id: string; pibo_session_id: string; role: WorkflowSessionLink["role"]; created_at: string };
+
+export class WorkflowStore {
+	private readonly db: DatabaseSync;
+
+	constructor(path = piboHomePath("workflows.sqlite")) {
+		const resolvedPath = resolve(path);
+		mkdirSync(dirname(resolvedPath), { recursive: true });
+		this.db = new DatabaseSync(resolvedPath);
+		this.db.exec(`
+			CREATE TABLE IF NOT EXISTS workflow_runs (
+				id TEXT PRIMARY KEY,
+				workflow_id TEXT NOT NULL,
+				workflow_version TEXT NOT NULL,
+				usage TEXT NOT NULL,
+				owner_scope TEXT NOT NULL,
+				status TEXT NOT NULL,
+				current_node_id TEXT NOT NULL,
+				project_id TEXT,
+				retry_count INTEGER NOT NULL,
+				max_retries INTEGER NOT NULL,
+				state_json TEXT NOT NULL,
+				initiator TEXT NOT NULL,
+				waiting_actions_json TEXT NOT NULL,
+				latest_reason TEXT,
+				created_at TEXT NOT NULL,
+				updated_at TEXT NOT NULL,
+				completed_at TEXT
+			);
+			CREATE TABLE IF NOT EXISTS workflow_trace_events (
+				id TEXT PRIMARY KEY,
+				workflow_run_id TEXT NOT NULL,
+				sequence INTEGER NOT NULL,
+				type TEXT NOT NULL,
+				node_id TEXT,
+				from_node_id TEXT,
+				to_node_id TEXT,
+				actor_id TEXT,
+				reason TEXT,
+				payload_json TEXT NOT NULL,
+				created_at TEXT NOT NULL,
+				UNIQUE(workflow_run_id, sequence)
+			);
+			CREATE TABLE IF NOT EXISTS workflow_session_links (
+				workflow_run_id TEXT NOT NULL,
+				pibo_session_id TEXT NOT NULL,
+				role TEXT NOT NULL,
+				created_at TEXT NOT NULL,
+				PRIMARY KEY(workflow_run_id, pibo_session_id, role)
+			);
+		`);
+	}
+
+	createRun(input: Omit<WorkflowRun, "id" | "createdAt" | "updatedAt"> & { id?: string }): WorkflowRun {
+		assertJsonObject(input.state, "workflow state");
+		const now = new Date().toISOString();
+		const run: WorkflowRun = { ...input, id: input.id ?? `wfr_${randomUUID()}`, createdAt: now, updatedAt: now };
+		this.db.prepare(`INSERT INTO workflow_runs (id, workflow_id, workflow_version, usage, owner_scope, status, current_node_id, project_id, retry_count, max_retries, state_json, initiator, waiting_actions_json, latest_reason, created_at, updated_at, completed_at) VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?)`).run(
+			run.id, run.workflowId, run.workflowVersion, run.usage, run.ownerScope, run.status, run.currentNodeId, run.projectId ?? null, run.retryCount, run.maxRetries, JSON.stringify(run.state), run.initiator, JSON.stringify(run.waitingActions), run.latestReason ?? null, run.createdAt, run.updatedAt, run.completedAt ?? null,
+		);
+		return run;
+	}
+
+	updateRun(run: WorkflowRun): WorkflowRun {
+		assertJsonObject(run.state, "workflow state");
+		const updated = { ...run, updatedAt: new Date().toISOString() };
+		this.db.prepare(`UPDATE workflow_runs SET status = ?, current_node_id = ?, retry_count = ?, state_json = ?, waiting_actions_json = ?, latest_reason = ?, updated_at = ?, completed_at = ? WHERE id = ?`).run(updated.status, updated.currentNodeId, updated.retryCount, JSON.stringify(updated.state), JSON.stringify(updated.waitingActions), updated.latestReason ?? null, updated.updatedAt, updated.completedAt ?? null, updated.id);
+		return updated;
+	}
+
+	getRun(id: string): WorkflowRun | undefined {
+		const row = this.db.prepare("SELECT * FROM workflow_runs WHERE id = ?").get(id) as RunRow | undefined;
+		return row ? runFromRow(row) : undefined;
+	}
+
+	listRuns(filter: { ownerScope?: string; projectId?: string } = {}): WorkflowRun[] {
+		const rows = filter.ownerScope
+			? this.db.prepare("SELECT * FROM workflow_runs WHERE owner_scope = ? ORDER BY updated_at DESC").all(filter.ownerScope) as RunRow[]
+			: this.db.prepare("SELECT * FROM workflow_runs ORDER BY updated_at DESC").all() as RunRow[];
+		return rows.map(runFromRow).filter((run) => !filter.projectId || run.projectId === filter.projectId);
+	}
+
+	appendTrace(input: Omit<WorkflowTraceEvent, "id" | "sequence" | "createdAt">): WorkflowTraceEvent {
+		assertJsonObject(input.payload, "workflow trace payload");
+		const next = Number((this.db.prepare("SELECT COALESCE(MAX(sequence), 0) + 1 AS next FROM workflow_trace_events WHERE workflow_run_id = ?").get(input.workflowRunId) as { next: number }).next);
+		const event: WorkflowTraceEvent = { ...input, id: `wfte_${randomUUID()}`, sequence: next, createdAt: new Date().toISOString() };
+		this.db.prepare(`INSERT INTO workflow_trace_events (id, workflow_run_id, sequence, type, node_id, from_node_id, to_node_id, actor_id, reason, payload_json, created_at) VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?)`).run(event.id, event.workflowRunId, event.sequence, event.type, event.nodeId ?? null, event.fromNodeId ?? null, event.toNodeId ?? null, event.actorId ?? null, event.reason ?? null, JSON.stringify(event.payload), event.createdAt);
+		return event;
+	}
+
+	listTrace(workflowRunId: string): WorkflowTraceEvent[] {
+		return (this.db.prepare("SELECT * FROM workflow_trace_events WHERE workflow_run_id = ? ORDER BY sequence ASC").all(workflowRunId) as TraceRow[]).map(traceFromRow);
+	}
+
+	linkSession(link: Omit<WorkflowSessionLink, "createdAt">): WorkflowSessionLink {
+		const createdAt = new Date().toISOString();
+		this.db.prepare("INSERT OR IGNORE INTO workflow_session_links (workflow_run_id, pibo_session_id, role, created_at) VALUES (?, ?, ?, ?)").run(link.workflowRunId, link.piboSessionId, link.role, createdAt);
+		return { ...link, createdAt };
+	}
+
+	listSessionLinks(workflowRunId: string): WorkflowSessionLink[] {
+		return (this.db.prepare("SELECT * FROM workflow_session_links WHERE workflow_run_id = ? ORDER BY created_at ASC").all(workflowRunId) as LinkRow[]).map((row) => ({ workflowRunId: row.workflow_run_id, piboSessionId: row.pibo_session_id, role: row.role, createdAt: row.created_at }));
+	}
+}
+
+function runFromRow(row: RunRow): WorkflowRun {
+	return { id: row.id, workflowId: row.workflow_id, workflowVersion: row.workflow_version, usage: row.usage, ownerScope: row.owner_scope, status: row.status, currentNodeId: row.current_node_id, projectId: row.project_id ?? undefined, retryCount: row.retry_count, maxRetries: row.max_retries, state: parseJsonObject(row.state_json), initiator: row.initiator, waitingActions: parseStringArray(row.waiting_actions_json), latestReason: row.latest_reason ?? undefined, createdAt: row.created_at, updatedAt: row.updated_at, completedAt: row.completed_at ?? undefined };
+}
+
+function traceFromRow(row: TraceRow): WorkflowTraceEvent {
+	return { id: row.id, workflowRunId: row.workflow_run_id, sequence: row.sequence, type: row.type, nodeId: row.node_id ?? undefined, fromNodeId: row.from_node_id ?? undefined, toNodeId: row.to_node_id ?? undefined, actorId: row.actor_id ?? undefined, reason: row.reason ?? undefined, payload: parseJsonObject(row.payload_json), createdAt: row.created_at };
+}
+
+function parseJsonObject(value: string | null | undefined): PiboJsonObject {
+	if (!value || value === "undefined") return {};
+	try {
+		const parsed = JSON.parse(value) as unknown;
+		return parsed && typeof parsed === "object" && !Array.isArray(parsed) ? parsed as PiboJsonObject : {};
+	} catch {
+		return {};
+	}
+}
+
+function parseStringArray(value: string | null | undefined): string[] {
+	if (!value || value === "undefined") return [];
+	try {
+		const parsed = JSON.parse(value) as unknown;
+		return Array.isArray(parsed) ? parsed.filter((item): item is string => typeof item === "string") : [];
+	} catch {
+		return [];
+	}
+}
+
+function assertJsonObject(value: unknown, label: string): asserts value is PiboJsonObject {
+	if (!value || typeof value !== "object" || Array.isArray(value)) throw new Error(`${label} must be a JSON object`);
+	JSON.stringify(value);
+}
diff --git a/src/workflows/types.ts b/src/workflows/types.ts
