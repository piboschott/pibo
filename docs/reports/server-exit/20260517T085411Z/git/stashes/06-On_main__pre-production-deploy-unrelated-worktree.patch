-  title?: string;
-  state?: string;
-  retryCount?: number;
-  maxRetries?: number;
-  createdAt: string;
-  updatedAt: string;
-};
-
-export type PiboProjectSessionWorkspace = {
-  projectId: string;
-  piboSessionId: string;
-  sourceProjectFolder: string;
-  worktreePath: string;
-  branchName?: string;
-  dockerWorkerId?: string;
-  webPort?: number;
-  cdpPort?: number;
-  status: "creating" | "ready" | "running" | "released" | "failed";
