{
  "compilerOptions": {
    "target": "ES2023",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "types": ["vite/client"],
    "paths": {
      "@chat-ui/*": ["../../chat-ui/src/*"]
    }
  },
  "include": ["**/*.ts", "**/*.tsx", "vite.config.ts"]
}
